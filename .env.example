# Copy to .env and fill in from https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match exactly what you set in Spotify app Redirect URIs (e.g. http://127.0.0.1:3847/auth/callback)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3847/auth/callback

# Port for the local overlay server
PORT=3847

# Listen address: 127.0.0.1 = only this PC. Use 0.0.0.0 if another PC (e.g. gaming PC + OBS) loads the overlay over LAN.
# HOST=127.0.0.1
# HOST=0.0.0.0
